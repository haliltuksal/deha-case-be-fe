# Backend API base URL (server-only — never exposed to the browser bundle)
LARAVEL_API_URL=http://localhost:8080

# Session cookie name set by the BFF on successful login
COOKIE_NAME=deha_token

# Optional cookie domain (leave empty for current host)
# COOKIE_DOMAIN=localhost

# Default outbound HTTP timeout against the Laravel API (ms)
REQUEST_TIMEOUT_MS=15000
