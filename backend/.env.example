# =============================================================================
# Dehasoft Case API — environment template
# =============================================================================
#
# Sensitive values use the `${VAR}` interpolation form. Laravel's phpdotenv
# substitutes them from the host / container environment when this file is
# evaluated, so secrets never have to be checked in.
#
# Bootstrap path: docker/php/entrypoint.sh copies this file to .env on first
# boot, then runs `php artisan key:generate` and `php artisan jwt:secret` to
# fill APP_KEY and JWT_SECRET if they are still empty after substitution.
#
# Override priority (highest first):
#   1. real environment variables on the running process
#   2. values set in `.env`
#   3. defaults baked into config/*.php and `env('FOO', 'default')` calls
#
# =============================================================================

# ---- Application ----
APP_NAME=DehasoftCaseApi
APP_ENV=${APP_ENV:-local}
APP_KEY=${APP_KEY}
APP_DEBUG=${APP_DEBUG:-true}
APP_URL=http://localhost:8080
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---- Logging ----
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---- Database (sensitive) ----
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=${DB_DATABASE:-dehasoft}
DB_USERNAME=${DB_USERNAME:-dehasoft}
DB_PASSWORD=${DB_PASSWORD}
DB_ROOT_PASSWORD=${DB_ROOT_PASSWORD}
DB_FORWARD_PORT=3307

# ---- Redis (cache, session, queue) ----
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=${REDIS_PASSWORD:-null}
REDIS_PORT=6379
REDIS_FORWARD_PORT=6380

CACHE_STORE=redis
CACHE_PREFIX=dehasoft
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ---- JWT (sensitive) ----
JWT_SECRET=${JWT_SECRET}
JWT_TTL=60
JWT_REFRESH_TTL=20160
# HS512 (SHA-512 HMAC). Stronger than the package default HS256 with no
# key-pair infrastructure overhead. The entrypoint script generates the
# secret automatically; run `php artisan jwt:secret` manually if you skip it.
JWT_ALGO=HS512

# ---- Currency / TCMB ----
TCMB_URL=https://www.tcmb.gov.tr/kurlar/today.xml
EXCHANGE_RATE_CACHE_TTL=86400
EXCHANGE_RATE_DEFAULT_BASE=TRY

# ---- Frontend / CORS ----
FRONTEND_URL=http://localhost:3000
